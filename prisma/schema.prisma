// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  title         String?
  bio           String?
  theme         String       @default("system")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]

  twoFactorEnabled Boolean?    @default(false)
  twofactors       TwoFactor[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id              String        @id @default(cuid())
  name            String
  slug            String?
  logo            String?
  createdAt       DateTime
  metadata        String?
  members         Member[]
  invitations     Invitation[]
  integrations    Integration[]
  rulesets        Ruleset[]
  reps            Rep[]
  contacts        Contact[]

  @@unique([slug])
  @@map("organization")
}

// ─── Routing Engine ────────────────────────────────────────────────────────────

model Ruleset {
  id             String       @id @default(cuid())
  rulesetId      String       @map("ruleset_id")
  organizationId String       @map("organization_id")
  name           String
  rulesJson      String       @map("rules_json")
  fallbackJson   String       @map("fallback_json")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  routingLogs    RoutingLog[]
  repSlas        RepSla[]
  staleAlerts    StaleAlert[]

  @@unique([organizationId, rulesetId])
  @@index([organizationId])
  @@map("rulesets")
}

model Rep {
  id             String       @id @default(cuid())
  repId          String       @map("rep_id")
  organizationId String       @map("organization_id")
  name           String
  email          String
  timezone       String?
  status         String       @default("active")
  oooUntil       DateTime?    @map("ooo_until")
  overflowTo     String?      @map("overflow_to")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  routingLogs    RoutingLog[]
  activities     Activity[]

  @@unique([organizationId, repId])
  @@index([organizationId])
  @@map("reps")
}

model RoundRobinState {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  rulesetId      String   @map("ruleset_id")
  rulePriority   Int      @map("rule_priority")
  currentIndex   Int      @default(0) @map("current_index")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, rulesetId, rulePriority])
  @@map("round_robin_state")
}

model Contact {
  id             String       @id @default(cuid())
  contactId      String       @map("contact_id")
  organizationId String       @map("organization_id")
  leadId         String?      @map("lead_id")
  email          String
  name           String?
  assignedRepId  String?      @map("assigned_rep_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  activities     Activity[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, contactId])
  @@index([organizationId])
  @@map("contacts")
}

model Activity {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  contactId       String    @map("contact_id")
  contact         Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  activityType    String    @map("activity_type")
  timestamp       DateTime
  repId           String?   @map("rep_id")
  rep             Rep?      @relation(fields: [repId], references: [id])
  durationMinutes Int?      @map("duration_minutes")
  outcome         String?
  notes           String?
  subject         String?
  meetingTime     DateTime? @map("meeting_time")
  metadataJson    String?   @map("metadata_json")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([contactId, activityType, timestamp])
  @@index([contactId])
  @@index([organizationId])
  @@map("activities")
}

model RoutingLog {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  leadId           String   @map("lead_id")
  rulesetId        String   @map("ruleset_id")
  ruleset          Ruleset  @relation(fields: [rulesetId], references: [id])
  ruleMatched      String?  @map("rule_matched")
  rulePriority     Int?     @map("rule_priority")
  assignmentMethod String?  @map("assignment_method")
  assignedRepId    String?  @map("assigned_rep_id")
  rep              Rep?     @relation(fields: [assignedRepId], references: [id])
  fallbackUsed     Boolean  @default(false) @map("fallback_used")
  attributesJson   String   @map("attributes_json")
  repStateJson     String   @map("rep_state_json")
  routingTimeMs    Int?     @map("routing_time_ms")
  assignedAt       DateTime @map("assigned_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([organizationId, assignedAt])
  @@index([rulesetId])
  @@map("routing_logs")
}

model StaleAlert {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  rulesetId       String   @map("ruleset_id")
  ruleset         Ruleset  @relation(fields: [rulesetId], references: [id], onDelete: Cascade)
  noActivityHours Int      @map("no_activity_hours")
  alertType       String   @default("webhook") @map("alert_type")
  webhookUrl      String   @map("webhook_url")
  cooldownHours   Int      @default(24) @map("cooldown_hours")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, rulesetId])
  @@map("stale_alerts")
}

model RepSla {
  id                         String   @id @default(cuid())
  organizationId             String   @map("organization_id")
  rulesetId                  String   @map("ruleset_id")
  ruleset                    Ruleset  @relation(fields: [rulesetId], references: [id], onDelete: Cascade)
  firstResponseTargetMinutes Int      @map("first_response_target_minutes")
  alertOnBreach              Boolean  @default(true) @map("alert_on_breach")
  alertWebhook               String?  @map("alert_webhook")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, rulesetId])
  @@map("rep_slas")
}

model Apikey {
  id                  String    @id
  configId            String    @default("default")
  name                String?
  start               String?
  referenceId         String
  prefix              String?
  key                 String
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean?  @default(true)
  rateLimitEnabled    Boolean?  @default(true)
  rateLimitTimeWindow Int?      @default(60000)
  rateLimitMax        Int?      @default(10)
  requestCount        Int?      @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime
  updatedAt           DateTime
  permissions         String?
  metadata            String?

  @@index([configId])
  @@index([referenceId])
  @@index([key])
  @@map("apikey")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime     @default(now())

  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("twoFactor")
}

model Integration {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String // e.g., 'slack', 'github', 'discord'
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  scope          String?
  metadata       String? // JSON string for additional data
  connectedAt    DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, provider])
  @@map("integration")
}
